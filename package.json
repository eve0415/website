{
  "type": "module",
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ],
    "#.storybook/*": [
      "./.storybook/*",
      "./.storybook/*.ts",
      "./.storybook/*.tsx"
    ]
  },
  "scripts": {
    "generate": "wrangler types && graphql-codegen && drizzle-kit generate",
    "migrate": "wrangler d1 migrations apply --local SKILLS_DB",
    "migrate:remote": "wrangler d1 migrations apply SKILLS_DB --remote",
    "test:update": "vp test run --typecheck --update",
    "storybook": "(find src -type d -name '__screenshots__' -exec rm -rf {} + 2>/dev/null || true) && storybook dev --port 6006",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@marsidev/react-turnstile": "^1.4.2",
    "@octokit/core": "^7.0.6",
    "@octokit/graphql-schema": "^15.26.1",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@rolldown/plugin-babel": "^0.2.2",
    "@storybook/addon-a11y": "^10.3.2",
    "@storybook/addon-docs": "^10.3.2",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-vitest": "^10.3.2",
    "@storybook/react-vite": "^10.3.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-form-start": "^1.28.5",
    "@tanstack/react-router": "^1.168.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.3",
    "@tanstack/start-storage-context": "^1.166.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260323.1",
    "@vitejs/devtools": "^0.1.8",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cloudflare": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.2",
    "mimetext": "^3.0.28",
    "msw": "^2.12.14",
    "nyc": "^18.0.0",
    "playwright": "^1.58.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.2",
    "tailwindcss": "^4.2.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.11",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plus": "^0.1.11",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.11",
    "vitest-browser-react": "^2.1.0",
    "wrangler": "^4.76.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.32.1"
    },
    "runtime": {
      "name": "node",
      "version": "24.14.x"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.13",
      "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
    }
  }
}
