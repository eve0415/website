{
  "type": "module",
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ],
    "#test/*": [
      "./test/*",
      "./test/*.ts",
      "./test/*.tsx"
    ],
    "#.storybook/*": [
      "./.storybook/*",
      "./.storybook/*.ts",
      "./.storybook/*.tsx"
    ]
  },
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "lint": "oxlint --type-aware --fix --fix-suggestions --report-unused-disable-directives && oxfmt",
    "test": "vitest run --typecheck",
    "test:update": "vitest run --typecheck --update",
    "generate": "wrangler types && graphql-codegen && drizzle-kit generate",
    "migrate": "wrangler d1 migrations apply --local SKILLS_DB",
    "migrate:remote": "wrangler d1 migrations apply SKILLS_DB --remote",
    "storybook": "(find src -type d -name '__screenshots__' -exec rm -rf {} + 2>/dev/null || true) && storybook dev --port 6006"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.2",
    "@cloudflare/vitest-pool-workers": "0.16.19",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-operations": "6.0.5",
    "@marsidev/react-turnstile": "1.5.3",
    "@octokit/core": "7.0.6",
    "@octokit/graphql-schema": "15.26.1",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@rolldown/plugin-babel": "0.2.3",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack-router-testing/react-router-testing": "0.7.0",
    "@tanstack-router-testing/react-start-testing": "0.7.0",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-form-start": "1.33.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.26",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "@vitejs/devtools": "0.3.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-istanbul": "4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "eslint-plugin-storybook": "10.4.6",
    "mimetext": "3.0.28",
    "msw": "2.14.6",
    "nyc": "18.0.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.61.1",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.1",
    "vite": "8.1.0",
    "vite-plugin-devtools-json": "1.0.0",
    "vitest": "4.1.9",
    "vitest-browser-react": "2.2.0",
    "wrangler": "4.104.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.x"
    }
  },
  "packageManager": "pnpm@11.9.0"
}
